class ArcTracker:
    def __init__(self):
        self.state_history: list[str] = []
        self.active_arc: str | None = None
        self.arc_progress: int = 0
        self.completed_arcs: dict[str, int] = {}

    def update(self, new_state: str) -> str | None:
        self.state_history.append(new_state)
        if len(self.state_history) > ARC_HISTORY_LENGTH:
            self.state_history.pop(0)

        completed = None
        for arc_name, sequence in SEMANTIC_ARCS.items():
            seq_len = len(sequence)
            tail = self.state_history[-seq_len:]
            if tail == sequence:
                completed = arc_name
                self.completed_arcs[arc_name] = (
                    self.completed_arcs.get(arc_name, 0) + 1
                )
                break

        self.active_arc = None
        self.arc_progress = 0
        for arc_name, sequence in SEMANTIC_ARCS.items():
            for length in range(min(4, len(self.state_history)), 0, -1):
                if self.state_history[-length:] == sequence[:length]:
                    self.active_arc = arc_name
                    self.arc_progress = length
                    break
            if self.active_arc:
                break

        return completed

    def get_explore_bias(self) -> float:
        if self.active_arc and self.active_arc in ARC_BONUSES:
            return ARC_BONUSES[self.active_arc]["explore_bias"]
        return 0.0

    def get_heal_bonus(self) -> float:
        if self.active_arc and self.active_arc in ARC_BONUSES:
            return ARC_BONUSES[self.active_arc]["heal_bonus"]
        return 0.0
    
    def get_wisdom_weight(self) -> float:
        total = sum(self.completed_arcs.values())
        return min(1.0, total / 10.0)

