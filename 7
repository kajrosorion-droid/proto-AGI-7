            priority = (1.2 + 0.3 * (self.emotional_memory['gratitude'] - 0.8)) * causal_mult
            new_goals.append({"type":"explore", "priority":priority, "target":None, "age":0, "persistence":20})
        if self.emotional_memory['grief'] > 0.7 and self.soul_weight < 0.4:
            new_goals.append({"type":"explore", "priority":1.1 * causal_mult, "target":None, "age":0, "persistence":15})
