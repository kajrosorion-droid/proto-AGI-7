class GlobalWorkspace:
    CAPACITY = 5
    def __init__(self):
        self.contents = []  # [(name, value, precision, age)]

    def update(self, signals: dict, epistemic_load: float, age: int):
        new = []
        for name, val in signals.items():
            prec = abs(val) * (1.0 - epistemic_load) * (1.0 - 0.02 * min(age % 20, 19))
            new.append((name, val, prec, 0))
        
        merged = self.contents + new
        merged = [(n, v, p*0.92, a+1) for n, v, p, a in merged]
        merged.sort(key=lambda x: x[2], reverse=True)
        self.contents = merged[:self.CAPACITY]
        return {c[0]: c for c in self.contents}

class TemporalContext:
    def __init__(self, size=10):
        self.buffer = deque(maxlen=size)
        
    def push(self, report_hash: int, binding: float, age: int):
        self.buffer.append((report_hash, binding, age))
        
    def get_continuity(self) -> float:
        if len(self.buffer) < 2: return 0.5
        recent = [b for _, b, _ in list(self.buffer)[-4:]]
        return float(np.clip(np.mean(recent), 0.0, 1.0))

