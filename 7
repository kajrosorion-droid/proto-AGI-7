def apply_global_given_queue(patterns, field, t):
    candidates = []
    for p in patterns:
        if not p.alive or p.age < GIVEN_MIN_AGE or p.given_cooldown > 0: continue
        if p.confidence < GIVEN_MAX_CONFIDENCE_FOR_CANDIDATE:
            priority = p.cognitive_tension - p.confidence; candidates.append((priority, p))
    if not candidates: return
    candidates.sort(key=lambda x: x[0], reverse=True)
    for i, (_, p) in enumerate(candidates[:GIVEN_GLOBAL_PRIORITY_COUNT]):
        forced = p.cognitive_tension > GIVEN_TENSION_TRIGGER
        p.apply_given_operator(field, forced=forced)

