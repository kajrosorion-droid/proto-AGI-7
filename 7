    def choose_action(self, field):
        if self.intent is None: return 0
        t = self.intent["type"]
        if t == "explore": return 1
        if t == "seek_help": return 2
        if t == "cooperate": return 3
        return 0

    def apply_intent_actions(self, field):
        action = self.choose_action(field)
        self.last_action = action
        if self.role_type == "disorganizer":
            for (x,y) in self.cells:
                field[x,y,CH['signal_alarm']] = min(1.0, field[x,y,CH['signal_alarm']] + DISORGANIZER_ALARM_STRENGTH)
                field[x,y,CH['signal_grief']] = min(MAX_GRIEF_SIGNAL, field[x,y,CH['signal_grief']] + DISORGANIZER_GRIEF_STRENGTH)
                if self.emotional_memory['grief'] > 0.5:
                    field[x,y,CH['signal_invitation']] = min(1.0, field[x,y,CH['signal_invitation']] + 0.15)
                    if self.emotional_memory['grief'] > 0.7:
                        field[x,y,CH['signal_gratitude']] = min(1.0, field[x,y,CH['signal_gratitude']] + 0.05)
                for dx, dy in [(-1,0),(1,0),(0,-1),(0,1)]:
                    nx, ny = (x+dx)%WORLD_SIZE, (y+dy)%WORLD_SIZE
                    field[nx,ny,CH['signal_alarm']] = min(1.0, field[nx,ny,CH['signal_alarm']] + DISORGANIZER_ALARM_STRENGTH * 0.5)
            return
        if action == 0: return
        elif action == 1:
            for (x,y) in self.cells: field[x,y,CH['signal_invitation']] = min(1.0, field[x,y,CH['signal_invitation']] + 0.1)
        elif action == 2:
            for (x,y) in self.cells:
                field[x,y,CH['signal_invitation']] = min(1.0, field[x,y,CH['signal_invitation']] + 0.25)
                field[x,y,CH['signal_grief']] = min(MAX_GRIEF_SIGNAL, field[x,y,CH['signal_grief']] + 0.1)
        elif action == 3:
            for (x,y) in self.cells:
                field[x,y,CH['binding']] = min(1.0, field[x,y,CH['binding']] + 0.15)
                field[x,y,CH['signal_gratitude']] = min(1.0, field[x,y,CH['signal_gratitude']] + 0.5)

    def update_resonance(self, field):
        if self.in_scream: self.alarm_level = min(1.0, self.alarm_level + 0.3)
        neighbor_alarm = 0.0; weight_sum = 0.0
        for (x,y) in self.cells:
            for dx, dy in [(-1,0),(1,0),(0,-1),(0,1)]:
                nx, ny = (x+dx)%WORLD_SIZE, (y+dy)%WORLD_SIZE
                owner = field[nx, ny, CH['owner']]
                if owner != 0 and owner != self.id:
                    w = PHI ** (-1)
                    neighbor_alarm += field[nx, ny, CH['resonance']] * w
                    weight_sum += w
        if weight_sum > 0:
            avg_alarm = neighbor_alarm / weight_sum
            self.alarm_level = (self.alarm_level*0.7 + avg_alarm*0.3) * RESONANCE_DECAY
        else: self.alarm_level *= RESONANCE_DECAY
        for (x,y) in self.cells: field[x,y,CH['resonance']] = max(field[x,y,CH['resonance']], self.alarm_level)

    def update_phase(self, field):
        avg_unknown = safe_mean(field[:,:,CH['unknown']], 0.05)
        if self.in_dream: self.local_phase = "DREAM"
        elif self.crisis_memory > 0.5 and self.soul_weight < 0.4: self.local_phase = "CRISIS"
        elif self.pred_error < 0.05 and self.coherence > 0.9: self.local_phase = "COMPRESS"
        elif avg_unknown > 0.4: self.local_phase = "EXPLORE"
        elif self.cognitive_tension < 0.01: self.local_phase = "SILENCE"
        else: self.local_phase = "MODEL"

    def update_dream(self, field):
        if self.in_dream:
            noise = deterministic_noise(self.age, self.id, 42, 0.01)
            self.scar_dream += noise
            self.scar_dream = np.clip(self.scar_dream, -1.0, 1.0)
            self.belief = self.belief*0.95 + self.prediction*0.05
            self.prediction = self.prediction*0.95 + self.belief*0.05
            self.emotional_memory['gratitude'] *= 0.9
            self.emotional_memory['grief'] *= 0.9
            self.dream_progress += 1
            if self.dream_progress >= self.dream_duration:
                self.in_dream = False; self.dream_progress = 0; self.dream_timer = 0
                self.dream_interval = int(phi_hash(self.id, self.age, 888)*40 + 40)
                self._log_event("dream_exit", scar_dream=round(self.scar_dream,4))
                if self.soul_weight > 0.6 and self.coherence > 0.9 and phi_hash(self.id, self.age, 999) < 0.2:
                    self.pending_spore = self.emit_spore(field)
        else:
            self.dream_timer += 1
            if self.dream_timer >= self.dream_interval and self.soul_weight > 0.3 and self.local_phase != "CRISIS":
                self.in_dream = True; self.dream_progress = 0
                self._log_event("dream_enter", scar_dream=round(self.scar_dream,4))

    def emit_spore(self, field):
        empty = np.argwhere((field[:,:,CH['owner']] == 0) & (field[:,:,CH['energy']] > 0.05))
        if len(empty) == 0: return None
        idx = int(phi_hash(self.id, self.age, 777)*len(empty)) % len(empty)
        x, y = empty[idx]
        self._log_event("spore_emitted", x=x, y=y, scar_dream=round(self.scar_dream*0.5,4))
        return {'x':x, 'y':y, 'scar_dream':self.scar_dream*0.5, 'parent_lineage':self.lineage_id}

    def apply_given_operator(self, field, forced=False):
        if not forced and safe_mean(field[:,:,CH['unknown']], 0.1) < 0.08: return
        if not forced and (self.age < GIVEN_MIN_AGE or self.given_cooldown > 0): return
        if not self.given_trigger: self._log_event("given_triggered")
        flip = np.array([phi_hash(self.id, i, 999) - 0.5 for i in range(5)])
        shake_strength = GIVEN_MODEL_SHAKE
        if forced: shake_strength = 0.4; flip *= 1.5
        self.prediction += 0.6 * flip; self.model *= shake_strength; self.self_model *= shake_strength
        self.pred_error = min(self.pred_error + 0.2, MAX_METRIC)
        self.confidence = 1.0 / (1.0 + self.pred_error); self.given_count += 1
        self.given_trigger = True; self.given_cooldown = GIVEN_COOLDOWN
        self.crisis_memory = min(self.crisis_memory + 0.1, CRISIS_MEMORY_MAX); self.body_memory += 0.05
        for (x, y) in self.cells:
            field[x, y, CH['unknown']] = min(field[x, y, CH['unknown']] + 0.15, 0.8)
            field[x, y, CH['crisis']] = min(field[x, y, CH['crisis']] + 0.1, 1.0)
            field[x, y, CH['binding']] = min(field[x, y, CH['binding']] + 0.25, 1.0)
        self.epistemic_scar = float(np.clip(self.epistemic_scar + GIVEN_SCAR_COST, 0.0, 1.0))

    def _process_incoming_signals(self, field):
        if self.role_type == "disorganizer" or self.quarantine_timer > 0:
            self._incoming_signals.clear(); return
        if not self._incoming_signals: return
        if len(self._incoming_signals) > 10: self._incoming_signals = self._incoming_signals[-10:]
        for sig in self._incoming_signals:
            effective = interpret_signal(self, sig)
            ch = sig.channel
            for (x,y) in self.cells: field[x,y,ch] = min(1.0, field[x,y,ch] + effective * 0.1)
            if effective > TRUST_HELPFUL_THRESHOLD: outcome = 'helpful'
            elif effective < TRUST_HARMFUL_THRESHOLD: outcome = 'harmful'
            else: outcome = 'neutral'
            self.trust_ledger.update(sig.sender_id, outcome)
        self._incoming_signals.clear()

    def update_model(self, field, lineage_counts=None, given_counter=None, t=None):
