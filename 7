        cf_shift = 0.15
        cf_g = np.clip(g + cf_shift, 0, 1) if 'разрыв' in report else np.clip(g - cf_shift, 0, 1)
        cf_coherence = 1.0 / (1.0 + abs(cf_g - g) * 2.0 + abs(t - pattern.cognitive_tension))
        meta_divergence = float(np.clip(1.0 - abs(cf_coherence - c), 0.0, 1.0))
        
        return report, base_bind, meta_divergence

