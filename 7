operator_scar = 0.0
proto_signals = np.zeros(NUM_SIGNALS)

def update_operator_scar(p):
    global operator_scar
    irreversible = p.crisis_memory * 0.5
    operator_scar = OPERATOR_MEMORY_DECAY * operator_scar + (1 - OPERATOR_MEMORY_DECAY) * irreversible

def apply_operator_influence(field, patterns, t):
    global operator_scar, proto_signals
    avg_err = safe_mean([p.pred_error for p in patterns if p.alive], 0.1)
    avg_soul = safe_mean([p.soul_weight for p in patterns if p.alive], 0.5)
    for ch_idx in range(CH['signal_alarm'], CH['signal_grief']+1): field[:,:,ch_idx] *= OPERATOR_SIGNAL_DECAY
    for p in patterns:
        if not p.alive: continue
        update_operator_scar(p)
        for (x,y) in p.cells:
            field[x,y,CH['signal_curiosity']] += OPERATOR_SIGNAL_STRENGTH * (1.0 - avg_err)
            field[x,y,CH['signal_warning']] += OPERATOR_SIGNAL_STRENGTH * avg_err
            field[x,y,CH['signal_invitation']] += OPERATOR_SIGNAL_STRENGTH * (1.0 - avg_soul)
            field[x,y,CH['signal_alarm']] += OPERATOR_SIGNAL_STRENGTH * operator_scar
    for ch_idx in range(CH['signal_alarm'], CH['signal_grief']+1): proto_signals[ch_idx - CH['signal_alarm']] = safe_mean(field[:,:,ch_idx], 0)
    field[:,:,CH['unknown']] *= UNKNOWN_DECAY; field[:,:,CH['unknown']] += UNKNOWN_BACKGROUND * (1.0 - UNKNOWN_DECAY)
    field[:,:,CH['binding']] *= 0.98; field[:,:,CH['binding']] = np.maximum(field[:,:,CH['binding']], BINDING_FLOOR)
    field[:,:,CH['surprise']] *= SURPRISE_DECAY; field[:,:,CH['signal_grief']] = np.clip(field[:,:,CH['signal_grief']], 0, MAX_GRIEF_SIGNAL)

def calculate_boredom(patterns, field):
    if not patterns: return 0.0
    err_history = []
    for p in patterns:
        if p.alive and hasattr(p, 'pred_error_history') and p.pred_error_history:
            err_history.extend(p.pred_error_history[-BOREDOM_WINDOW:])
    if not err_history: return 0.0
    avg_recent_err = np.mean(err_history)
    avg_unknown = safe_mean(field[:,:,CH['unknown']], 0.1)
    avg_tension = safe_mean([p.cognitive_tension for p in patterns if p.alive], 0.01)
    boredom_score = 0.0
    if avg_recent_err < BOREDOM_ERR_THRESHOLD: boredom_score += 0.4
    if avg_unknown < BOREDOM_UNKNOWN_THRESHOLD: boredom_score += 0.4
    if avg_tension < BOREDOM_TENSION_THRESHOLD: boredom_score += 0.2
    return boredom_score

def crisis_injection(field, t):
    if t % CRISIS_PERIOD == 0 and t > 0:
        intensity = CRISIS_INTENSITY * (1.0 + 0.5 * np.sin(t * 0.01))
        for x in range(WORLD_SIZE):
            for y in range(WORLD_SIZE):
                if phi_hash(x, y, t) < intensity:
                    field[x, y, CH['energy']] += (phi_hash(x, y, t+1) - 0.5) * 0.2
                    field[x, y, CH['unknown']] = min(0.8, field[x, y, CH['unknown']] + 0.15)
                    field[x, y, CH['crisis']] = min(1.0, field[x, y, CH['crisis']] + 0.3)

def emergency_rescue(patterns, field, t):
    global last_rescue_t, next_pattern_id
    alive = [p for p in patterns if p.alive]
    if len(alive) >= MIN_POPULATION_FOR_SPAWN: return patterns
    if t - last_rescue_t < 30: return patterns
    normal_count = len([p for p in alive if p.role_type == "normal"])
    if normal_count >= OVERPOPULATION_CAP: return patterns
    last_rescue_t = t; num_rescue = max(5, MIN_PATTERNS_GUARANTEED - len(alive))
    donor_index = int(phi_hash(t, 0, 7777) * len(alive)) if alive else -1
    donor = alive[donor_index] if donor_index >= 0 else None
    new_patterns = []
    for i in range(num_rescue):
        if normal_count + i >= OVERPOPULATION_CAP: break
        seed = int(phi_hash(t, i, 999) * WORLD_SIZE * WORLD_SIZE)
        x, y = seed % WORLD_SIZE, (seed // WORLD_SIZE) % WORLD_SIZE
        field[x, y, CH['energy']] += 0.2; field[x, y, CH['unknown']] += 0.1
        field[x, y, CH['owner']] = 0
        pid = next_pattern_id; next_pattern_id += 1
        cells = {(x, y)}; p = Pattern(pid, cells, parent=donor)
        if donor:
            p.belief = donor.belief + np.array([phi_hash(pid, i, 99)-0.5 for i in range(5)]) * 0.1
            p.model = donor.model.copy()
        p.update_properties(field); p.update_model(field); new_patterns.append(p)
    return patterns + new_patterns

def anti_conformist_injection(patterns, t):
    if t % ANTI_CONFORMIST_INTERVAL != 0 or t == 0: return
    alive = [p for p in patterns if p.alive and p.age >= MIN_AGE_FOR_ANTI_CONFORMIST]
    if not alive: return
    mutant_index = int(phi_hash(t, 0, 777) * len(alive)); mutant = alive[mutant_index]
    mutant.emotional_memory['gratitude'] = 0.1; mutant.emotional_memory['grief'] = 0.1
    mutant.semantic_state = "neutral"; mutant.intent = None; mutant.intent_commitment = 0.0
    mutant.goals = [{"type":"explore", "priority":1.5, "target":None, "age":0, "persistence":40}]
    mutant.last_intent_switch_age = mutant.age; mutant._log_event("anti_conformist_injected", t=t)

def spawn_unknown_patterns(field, patterns, t, max_new=MAX_UNKNOWN_SPAWN_PER_STEP):
    global next_pattern_id
    avg_unknown = safe_mean(field[:,:,CH['unknown']], 0)
    alive = [p for p in patterns if p.alive]; normal_count = len([p for p in alive if p.role_type == "normal"])
    if avg_unknown < UNKNOWN_SPAWN_THRESHOLD or normal_count >= OVERPOPULATION_CAP: return patterns
    prob = UNKNOWN_SPAWN_PROB * (avg_unknown / UNKNOWN_SPAWN_THRESHOLD)
    prob *= min(1.0, normal_count / OVERPOPULATION_THRESHOLD)
    new_patterns = []; new_count = 0; done = False
    for x in range(WORLD_SIZE):
        if done: break
        for y in range(WORLD_SIZE):
            if new_count >= max_new or normal_count + new_count >= OVERPOPULATION_CAP: done = True; break
            if field[x,y,CH['owner']] != 0: continue
            if field[x,y,CH['unknown']] > 0.5 and phi_hash(x, y, t) < prob:
                pid = next_pattern_id; next_pattern_id += 1
                cells = {(x, y)}; p = Pattern(pid, cells)
                p.update_properties(field); p.update_model(field); new_patterns.append(p)
                new_count += 1; field[x,y,CH['unknown']] *= 0.8
    return patterns + new_patterns

def resolve_competitions_spatial(patterns, field, max_dist=COMPETITION_MAX_DISTANCE):
    alive = [p for p in patterns if p.alive and p.cells]
    if len(alive) < 2: return
    cell_size = max(1, max_dist); spatial_map = {}
    for p in alive:
        cx = sum(c[0] for c in p.cells) // len(p.cells)
        cy = sum(c[1] for c in p.cells) // len(p.cells)
        key = (cx // cell_size, cy // cell_size); spatial_map.setdefault(key, []).append(p)
    checked_pairs = set()
    for (gx, gy), group in spatial_map.items():
        for dx in [-1, 0, 1]:
            for dy in [-1, 0, 1]:
                neighbor_key = (gx + dx, gy + dy)
                if neighbor_key not in spatial_map: continue
                others = spatial_map[neighbor_key]
                for p1 in group:
                    for p2 in others:
                        if p1.id >= p2.id: continue
                        pair = (p1.id, p2.id)
                        if pair in checked_pairs: continue
                        if not p1.cells & p2.cells: continue
                        checked_pairs.add(pair); p1.compete(p2, field)

def field_dynamics(field, scar, patterns, t):
    field[:,:,CH['vorticity']] *= VORTICITY_DECAY
    field[:,:,CH['vorticity']] += np.gradient(field[:,:,CH['energy']])[0] * GRADIENT_SENSITIVITY + np.gradient(field[:,:,CH['energy']])[1] * GRADIENT_SENSITIVITY
    for x in range(WORLD_SIZE):
        for y in range(WORLD_SIZE): field[x,y,CH['vorticity']] += deterministic_noise(t, x, y, 0.01)
    for p in patterns:
        if not p.alive: continue
        for (x,y) in p.cells:
            scar[x,y] += AGENT_SCAR_SENSE * p.epistemic_load
            field[x,y,CH['binding']] = min(1.0, field[x,y,CH['binding']] + AGENT_BINDING_SENSE * p.unresolved_contradiction)
    scar *= FIELD_DECAY; field[:,:,CH['scar']] = np.clip(scar, 0, SCAR_SATURATION)
    field[:,:,CH['energy']] += HEARTBEAT_AMPLITUDE * np.sin(t * HEARTBEAT_FREQ + field[:,:,CH['vorticity']])
    field[:,:,CH['energy']] += SCAR_ENERGY_COUPLING * field[:,:,CH['scar']]
    field[:,:,CH['energy']] += VORTICITY_COUPLING * field[:,:,CH['vorticity']]
    field[:,:,CH['flux']] *= GLOBAL_VISCOSITY
    for x in range(WORLD_SIZE):
        for y in range(WORLD_SIZE): field[x,y,CH['flux']] += LOCAL_FATIGUE * deterministic_noise(t+1000, x, y, 0.01)
    return field, scar

def process_spores(patterns, field):
    global next_pattern_id
    new_patterns = []
    alive = [p for p in patterns if p.alive]; normal_count = len([p for p in alive if p.role_type == "normal"])
    for p in patterns:
        if p.alive and p.pending_spore and p.pending_spore['x'] is not None:
            if normal_count >= OVERPOPULATION_CAP: p.pending_spore = None; continue
            spore = p.pending_spore
            if field[spore['x'], spore['y'], CH['owner']] != 0: p.pending_spore = None; continue
            pid = next_pattern_id; next_pattern_id += 1
            cells = {(spore['x'], spore['y'])}; child = Pattern(pid, cells, parent=p)
            child.scar_dream = spore['scar_dream']; child.update_properties(field); child.update_model(field)
            new_patterns.append(child); field[spore['x'], spore['y'], CH['owner']] = child.id
            p.pending_spore = None; normal_count += 1
    return patterns + new_patterns

