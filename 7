    def _heal_epistemic_scar(self):
        if self.epistemic_scar <= EPISTEMIC_SCAR_MIN:
            return
        scar_pressure = self.epistemic_scar ** 2
        base_rate = 0.0
        if (self.semantic_state in ["contentment", "grateful_but_cautious"] and
                self.emotional_memory['gratitude'] > HEALING_GRATITUDE_MIN):
            crisis_penalty = 1.0 - np.clip(self.crisis_memory * 0.8, 0.0, 0.5)
            base_rate += (1.0 - EPISTEMIC_HEALING_RATE) * scar_pressure * crisis_penalty
        if self.age > HEAL_WISDOM_AGE and self.coherence > WISDOM_COHERENCE_MIN:
            base_rate += HEAL_WISDOM_BONUS
        if self.age > HEAL_VETERAN_AGE and self.coherence > 0.7:
            base_rate += HEAL_VETERAN_BONUS
        if (self.age > HEAL_ENLIGHTENED_AGE and
                self.emotional_memory['gratitude'] > ENLIGHTENED_GRATITUDE_MIN and
                self.epistemic_scar > ENLIGHTENED_SCAR_THRESHOLD):
            if self.coherence > ENLIGHTENED_COHERENCE_FLOOR:
                base_rate += HEAL_ENLIGHTENED_BONUS
        base_rate += self.arc_tracker.get_heal_bonus()
        heal = float(np.clip(base_rate, 0.0, SCAR_HEAL_CAP_PER_STEP))
        self.epistemic_scar = max(EPISTEMIC_SCAR_MIN, self.epistemic_scar - heal)

    def _check_semantic_stagnation(self):
        if self.role_type == "disorganizer" or self.quarantine_timer > 0:
            return
        if self.semantic_state == self._prev_semantic_state:
            self.semantic_state_age += 1
        else:
            self.semantic_state_age = 0
            self._prev_semantic_state = self.semantic_state
        if self.semantic_state_age > STAGNATION_GRIEF_THRESHOLD:
            boost = STAGNATION_GRIEF_BOOST * (self.semantic_state_age / STAGNATION_GRIEF_THRESHOLD)
            self.emotional_memory['grief'] = float(np.clip(self.emotional_memory['grief'] + boost, 0.0, MAX_GRIEF_SIGNAL))
        if self.semantic_state_age > STAGNATION_GRIEF_THRESHOLD * 3:
            bleed = STAGNATION_BLEED_RATE * (self.semantic_state_age / (STAGNATION_GRIEF_THRESHOLD * 3))
            self.emotional_memory['gratitude'] = float(np.clip(self.emotional_memory['gratitude'] - bleed, 0.0, 1.0))
        if (self.semantic_state_age > FOLD_STAGNATION_AGE and
                self.emotional_memory['gratitude'] > FOLD_GRATITUDE_MIN and
                self.epistemic_scar > EPISTEMIC_SCAR_MIN):
            self._apply_fold()

    def _apply_fold(self):
        self.emotional_memory['gratitude'] = FOLD_GRATITUDE_RESET
        self.emotional_memory['grief'] = float(np.clip(self.emotional_memory['grief'] + FOLD_GRIEF_BOOST, 0.0, MAX_GRIEF_SIGNAL))
        self.crisis_memory = min(CRISIS_MEMORY_MAX, self.crisis_memory + FOLD_CRISIS_SPIKE)
        self.epistemic_scar = max(EPISTEMIC_SCAR_MIN, self.epistemic_scar - FOLD_SCAR_RELEASE)
        self.semantic_state = "seeking_comfort"
        self.semantic_state_age = 0
        self.fold_cooldown = FOLD_COOLDOWN_DURATION
        self._log_event("fold", grat=FOLD_GRATITUDE_RESET, grief=self.emotional_memory['grief'])

    def update_world_model(self, observed):
        pred = self.world_state + self.world_model[self.last_action]
        error = observed - pred
        if np.mean(np.abs(error)) > 0.5:
            scar_delta = 0.005 * (1.0 - self.crisis_memory)
            self.epistemic_scar = min(1.0, self.epistemic_scar + scar_delta)
            return float(np.mean(error**2))
        lr = min(self.genome['learning_rate'] * 0.1, 0.05)
        self.world_model[self.last_action] += lr * np.clip(error, -1.0, 1.0)
        self.world_state = observed.copy()
        return float(np.mean(error**2))

