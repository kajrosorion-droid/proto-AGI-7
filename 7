class ConceptGraph:
    def __init__(self):
        self.nodes: dict = {}
        self.edges: dict = defaultdict(lambda: defaultdict(int))
        self._prev_sig = None

    def update(self, signature: tuple, values: np.ndarray):
        if signature not in self.nodes:
            self.nodes[signature] = {
                "count": 0,
                "value": np.zeros(4),
            }
        self.nodes[signature]["count"] += 1
        self.nodes[signature]["value"] += values

        if self._prev_sig is not None:
            self.edges[self._prev_sig][signature] += 1

        self._prev_sig = signature

    def similarity(self, other: "ConceptGraph") -> float:
        shared_nodes = set(self.nodes) & set(other.nodes)
        if not shared_nodes:
            return 0.0

        total_self  = sum(self.nodes[s]["count"]  for s in shared_nodes)
        total_other = sum(other.nodes[s]["count"] for s in shared_nodes)
        total_all   = (sum(n["count"] for n in self.nodes.values()) +
                       sum(n["count"] for n in other.nodes.values()))

        return (total_self + total_other) / max(total_all, 1)

