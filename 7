class TrustLedger:
    def __init__(self):
        self.entries: dict[int, float] = {}

    def update(self, sender_id: int, outcome: str):
        current = self.entries.get(sender_id, TRUST_BASE)
        delta = {
            'helpful': TRUST_DELTA_HELPFUL,
            'neutral': TRUST_DELTA_NEUTRAL,
            'harmful': TRUST_DELTA_HARMFUL
        }.get(outcome, 0.0)
        if outcome == 'helpful' and current > 0.6:
            delta *= 1.2
        new_val = np.clip(current + delta, 0.0, 1.0)
        self.entries[sender_id] = new_val

    def get(self, sender_id: int) -> float:
        return self.entries.get(sender_id, TRUST_BASE)

def interpret_signal(receiver, sig: SemanticSignal) -> float:
    weight = sig.strength
    if (sig.sender_context == "grateful_but_cautious" and 
            receiver.semantic_state == "seeking_comfort"):
        weight *= 1.4
    if sig.sender_age > WISDOM_AGE:
        weight *= 1.2
    if hasattr(receiver, 'concept_graph') and hasattr(sig, '_sender_concept_graph'):
        sim = receiver.concept_graph.similarity(sig._sender_concept_graph)
        weight *= (1.0 + 0.4 * sim)
    if hasattr(receiver, 'trust_ledger'):
        trust = receiver.trust_ledger.get(sig.sender_id)
        weight *= (0.6 + 0.8 * trust)
        if trust > 0.7 and sig.channel == CH['signal_gratitude']:
            weight *= TRUST_GRATITUDE_AMPLIFY
    if sig.sender_lineage == receiver.lineage_id:
        weight *= 1.1
    return np.clip(weight, 0.0, 2.5)

